# ─────────────────────────────────────────
# rag-eval — Environment Variables Template
# ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# ── Required ──────────────────────────────
# Groq API key — LLM judge + RAG generator
# Get free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Optional: HF Hub ──────────────────────
# Required only if pushing to a PRIVATE dataset.
# Public datasets (recommended) load without auth.
HF_TOKEN=hf_your_hugging_face_token_here

# ── Optional: Model Overrides ─────────────
# Override the LLM judge (default: groq/llama-3.3-70b-versatile)
# JUDGE_MODEL=groq/llama-3.3-70b-versatile

# Override the RAG generator LLM
# RAG_MODEL=groq/llama-3.3-70b-versatile

# Override embedding model (default: sentence-transformers/all-MiniLM-L6-v2)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Optional: Grafana Cloud ───────────────
# Required for pushing metrics to Grafana Cloud dashboard.
# Setup: https://grafana.com → Your Stack → Metrics → Send Metrics
#
# URL format: https://influx-prod-XX.grafana.net/api/v1/push/influx/write
GRAFANA_URL=https://influx-prod-XX.grafana.net/api/v1/push/influx/write
GRAFANA_USER=123456
GRAFANA_API_KEY=glc_your_grafana_api_key_here

# ── CI Variables (set automatically in GitHub Actions) ──
# PR_NUMBER=${github.event.pull_request.number}
# GITHUB_RUN_ID=${github.run_id}
